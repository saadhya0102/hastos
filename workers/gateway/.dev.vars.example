# Local secrets for `wrangler dev`. Copy to `.dev.vars` and fill in. Never commit `.dev.vars`.

# AI providers
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Execution backend selection: "piston" | "judge0" | "auto" (auto prefers Piston if PISTON_URL set)
EXEC_BACKEND=auto

# Piston (primary grader). SELF-HOSTED — the public emkc.org API is no longer
# free (auth token required as of 2026-02-15; keys not granted for projects like
# this). See infra/piston/README.md. Any of these URL forms work; the adapter
# resolves the /api/v2 path automatically:
#
# Self-hosted, local (works when the Worker runs locally via `wrangler dev`):
PISTON_URL=http://localhost:2000
# Self-hosted, exposed to the internet via Cloudflare Tunnel (needed in prod):
# PISTON_URL=https://piston.yourdomain.com
# (Only if EngineerMan issued you a key — usually not: https://emkc.org/api/v2/piston)

# Judge0 (optional fallback grader — self-hosted or RapidAPI)
# Self-hosted example:
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=
# RapidAPI example (uncomment + set host; JUDGE0_AUTH_TOKEN becomes the RapidAPI key):
# JUDGE0_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_AUTH_TOKEN=your-rapidapi-key
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Firebase (for ID token verification in production; ALLOW_ANON=true bypasses in dev)
FIREBASE_PROJECT_ID=your-project-id
