# Public Firebase web config (safe to ship to the browser).
# From Firebase console -> Project settings -> Your apps -> SDK setup.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef

# Base URL of the Cloudflare Worker gateway (holds all secrets).
VITE_GATEWAY_URL=http://127.0.0.1:8787
