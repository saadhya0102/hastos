# Judge0 configuration for the HastOS execution box.
# Copy to `judge0.conf` next to the compose file and fill in strong secrets.
# Keep this file private (it is gitignored via *.conf is NOT — so do not commit the real one).

# ---- Postgres ----
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=judge0
POSTGRES_USER=judge0
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ---- Auth: require this token on every request (the Worker sends it) ----
AUTHN_HEADER=X-Auth-Token
AUTHN_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN

# ---- Sandbox safety limits (conservative defaults) ----
ENABLE_NETWORK=false
CPU_TIME_LIMIT=5
CPU_EXTRA_TIME=1
WALL_TIME_LIMIT=12
MEMORY_LIMIT=262144
MAX_PROCESSES_AND_OR_THREADS=80
ENABLE_PER_PROCESS_AND_THREAD_TIME_LIMIT=false
MAX_FILE_SIZE=10240
ALLOW_ENABLE_NETWORK=false

# Number of worker threads consuming the queue (tune to your core count; A1 free = up to 4)
COUNT=4
