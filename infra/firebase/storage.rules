rules_version = '2';

// HastOS Storage rules. Users can manage only their own files; everything else is denied.
service firebase.storage {
  match /b/{bucket}/o {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Per-user private files (avatars, snippet attachments, etc.). 5 MB cap.
    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.size < 5 * 1024 * 1024;
    }

    // Publicly readable assets (course images, diagrams) — authored/uploaded out of band.
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
